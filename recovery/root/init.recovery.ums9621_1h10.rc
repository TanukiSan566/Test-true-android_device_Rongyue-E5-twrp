import /init.recovery.common.rc

# 原厂 init.recovery.common.rc 里只写了 adb,vser,gser 和 vser 这两种组合的 ConfigFS 触发条件，
# 但 TWRP 自己默认会把 sys.usb.config 设成单纯的 "adb"（不带 vser/gser），根本对不上原厂那两条规则，
# UDC 永远没人去 write，所以 dmesg 里一直卡在 "waiting musb udc start"。
# 这里照抄原厂那套手法，单独给纯 "adb" 补一条一样的 ConfigFS 绑定规则。
on property:sys.usb.configfs=1 && property:sys.usb.ffs.ready=1 && property:sys.usb.config=adb
    write /config/usb_gadget/g1/idVendor 0x18D1
    write /config/usb_gadget/g1/idProduct 0x4EE7
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "adb"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    rm /config/usb_gadget/g1/configs/b.1/f10
    rm /config/usb_gadget/g1/configs/b.1/f11

    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1

    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

# TWRP 自己不会主动设置 sys.usb.configfs=1 / sys.usb.ffs.ready=1 这两个原厂脚本需要的前置属性，
# 这里在 recovery 服务类启动之后手动点火一次，确保上面这条以及原厂那两条 adb,vser,gser / vser 规则真正会被触发
on property:sys.usb.ffs.ready=1
    setprop sys.usb.configfs 1
